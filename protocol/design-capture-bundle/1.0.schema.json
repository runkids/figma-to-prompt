{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unnotech.dev/schemas/design-capture-bundle/1.0.schema.json",
  "title": "Design Capture Bundle manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "producer",
    "capturedAt",
    "source",
    "root",
    "files"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$"
    },
    "producer": {
      "type": "object",
      "required": ["name", "version", "protocolVersion"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "version": { "type": "string", "minLength": 1, "maxLength": 80 },
        "protocolVersion": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": [
        "provider",
        "fileKey",
        "fileVersionId",
        "nodeIds",
        "sourceUrl"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["figma-plugin", "figma-mcp", "figma-rest", "manual"]
        },
        "fileKey": { "type": ["string", "null"], "maxLength": 500 },
        "fileVersionId": { "type": ["string", "null"], "maxLength": 500 },
        "nodeIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "sourceUrl": {
          "type": ["string", "null"],
          "format": "uri",
          "maxLength": 4000
        },
        "locatorPath": { "const": "mcp/figma-locator.json" }
      },
      "additionalProperties": true
    },
    "root": {
      "type": "object",
      "required": [
        "id",
        "name",
        "structurePath",
        "promptPath",
        "primaryReferencePath",
        "targetViewport",
        "referencePaths"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 500 },
        "name": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "structurePath": { "const": "design/nodes.json" },
        "promptPath": { "const": "prompt.md" },
        "primaryReferencePath": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "targetViewport": {
          "type": "object",
          "required": ["width", "height", "referencePath"],
          "properties": {
            "width": { "type": "integer", "minimum": 1, "maximum": 32768 },
            "height": { "type": "integer", "minimum": 1, "maximum": 32768 },
            "referencePath": { "type": "string", "minLength": 1, "maxLength": 1000 }
          },
          "additionalProperties": false
        },
        "fallbackPaths": {
          "type": "array",
          "maxItems": 4096,
          "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
        },
        "referencePaths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      },
      "additionalProperties": true
    },
    "files": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4096,
      "items": {
        "type": "object",
        "required": ["path", "role", "mediaType", "size", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 240 },
          "role": {
            "type": "string",
            "enum": [
              "design-structure",
              "reference-render",
              "design-asset",
              "derived-prompt",
              "provenance"
            ]
          },
          "mediaType": { "type": "string", "minLength": 1, "maxLength": 160 },
          "size": { "type": "integer", "minimum": 0, "maximum": 134217728 },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "nodeId": { "type": ["string", "null"], "maxLength": 500 },
          "purpose": { "type": "string", "enum": ["rendered-fallback"] },
          "fallbackVariant": { "type": "string", "enum": ["pixel", "vector"] },
          "fallbackReasons": {
            "type": "array",
            "maxItems": 16,
            "items": { "type": "string", "minLength": 1, "maxLength": 160 }
          },
          "pixelDimensions": {
            "type": "object",
            "required": ["width", "height"],
            "properties": {
              "width": { "type": "integer", "minimum": 1, "maximum": 32768 },
              "height": { "type": "integer", "minimum": 1, "maximum": 32768 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    },
    "fidelity": {
      "type": "object",
      "required": [
        "policy",
        "coveragePath",
        "candidateNodeCount",
        "coveredNodeCount",
        "unresolvedNodeIds",
        "exactVerification"
      ],
      "properties": {
        "policy": { "const": "fail-closed" },
        "coveragePath": { "const": "fidelity/coverage.json" },
        "candidateNodeCount": { "type": "integer", "minimum": 0, "maximum": 100000 },
        "coveredNodeCount": { "type": "integer", "minimum": 0, "maximum": 100000 },
        "unresolvedNodeIds": {
          "type": "array",
          "maxItems": 100000,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "exactVerification": {
          "type": "object",
          "required": ["required", "method", "referencePath", "referenceStability"],
          "properties": {
            "required": { "const": true },
            "method": { "const": "rgba-pixel-equality" },
            "referencePath": { "type": "string", "minLength": 1, "maxLength": 1000 },
            "referenceStability": {
              "type": "object",
              "required": ["renderCount", "width", "height", "differentPixels", "maxChannelDelta"],
              "properties": {
                "renderCount": { "const": 2 },
                "width": { "type": "integer", "minimum": 1, "maximum": 32768 },
                "height": { "type": "integer", "minimum": 1, "maximum": 32768 },
                "differentPixels": { "const": 0 },
                "maxChannelDelta": { "const": 0 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "maxItems": 1000,
      "items": { "type": "string", "maxLength": 2000 }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
