{
  "name": "figma-to-prompt",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:sandbox": "vite build --watch --config vite.config.sandbox.ts",
    "dev:ui": "vite build --watch --config vite.config.ui.ts",
    "build": "pnpm run build:sandbox && pnpm run build:ui",
    "build:sandbox": "vite build --config vite.config.sandbox.ts",
    "build:ui": "vite build --config vite.config.ui.ts",
    "lint": "oxlint src/ tests/ scripts/",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:plugin": "node scripts/smoke-plugin-bundle.mjs",
    "visual:diff": "node scripts/compare-png.mjs",
    "release": "./scripts/release.sh",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.106.0",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^26.1.1",
    "oxlint": "^1.60.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "@jsquash/avif": "1.1.2-single-thread-only",
    "preact": "^10.29.1"
  }
}
