{
  // Root config doubles as (a) the base for tsconfig.ui.json / tsconfig.sandbox.json
  // AND (b) the config used by `tsc --noEmit` at the repo root (our post-edit hook).
  // To make the hook see BOTH the UI (Preact + DOM) and sandbox (Figma plugin)
  // surfaces at once, we union their libs/types here. The per-target configs
  // still exist because vite builds each output separately.
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": false,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    // @figma/plugin-typings is a scoped package (not under @types/…) so we rely
    // on default type acquisition (do NOT set typeRoots here) and pull the
    // global Figma API declarations explicitly.
    "types": ["@figma/plugin-typings", "node"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
